#!/usr/bin/expect -f

set timeout 5
set summary [lindex $argv 0]

spawn pnpm changeset

expect "would you like to include"
send " "
send "\r"

expect "major bump"
send "\r"

expect "minor bump"
send "\r"

expect "summary"
send "$summary\r"

expect {
  "desired changeset" { send "\r"; exp_continue }
  eof
}
